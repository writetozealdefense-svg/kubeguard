[
  {
    "id": "KG-001",
    "title": "Privileged container",
    "severity": "critical",
    "category": "host-access",
    "resource": {
      "kind": "Deployment",
      "namespace": "payments",
      "name": "checkout"
    },
    "evidence": [
      {
        "path": "spec.containers[checkout].securityContext.privileged",
        "value": "true"
      }
    ],
    "remediation": {
      "summary": "Remove securityContext.privileged or set it to false; grant only the specific capabilities the workload needs.",
      "snippet": "securityContext:\n  privileged: false"
    },
    "grants": [
      "ContainerEscape",
      "NodeAccess"
    ],
    "refs": [
      {
        "framework": "CIS",
        "id": "5.2.1"
      },
      {
        "framework": "NSA",
        "id": "k8s-hardening",
        "title": "Pod security"
      },
      {
        "framework": "ATT\u0026CK",
        "id": "T1611"
      }
    ]
  },
  {
