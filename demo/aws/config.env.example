# Copy to config.env and fill in. config.env is git-ignored.
# Sourced by up.sh / scan.sh / down.sh.

# Path to the PRIVATE key matching the EC2 key_name in terraform.tfvars.
SSH_KEY="$HOME/.ssh/my-demo-key.pem"

# SSH user for the Ubuntu AMI (don't change unless you swap the AMI).
SSH_USER="ubuntu"
