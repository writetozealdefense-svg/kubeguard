# Build output
/dist/
/bin/
# Root-anchored so these match the built binaries only — a bare `kubeguard`
# pattern also matches the charts/kubeguard/ directory and silently un-tracks it.
/kubeguard
/kubeguard.exe
/kubectl-kubeguard
/kubectl-kubeguard.exe

# Test / coverage artifacts. Note: match report artifacts by extension, NOT
# `coverage.*` — that also swallows Go source files named coverage.go (e.g.
# internal/graph/coverage.go), silently un-tracking them.
*.out
coverage.html
coverage.txt
coverage.xml
coverage.cov

# Local scan outputs and history stores
*.sarif
*.kgdb
*.sqlite

# Generated demo output (regenerated live during the demo)
/demo/evidence/
/demo/evidence-hardened/
/demo/report.*

# Node / frontend
node_modules/
web/dist/
web/playwright-report/
web/test-results/

# Nested mount of the sibling workspace folder (not part of this repo)
/KubeGuard/

# Editor / OS
.idea/
.vscode/
.DS_Store
*.exe~
*.test
