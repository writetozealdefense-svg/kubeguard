# Copy to `.env` and adjust as needed: `cp .env.example .env`
# docker compose reads these automatically. All have safe local defaults, so
# `.env` is optional.

# Dashboard login token (bearer token typed on the UI login screen).
KUBEGUARD_ADMIN_TOKEN=local-admin

# Postgres credentials (local only — never reuse these in production).
POSTGRES_USER=kubeguard
POSTGRES_PASSWORD=kubeguard
POSTGRES_DB=kubeguard

# Host port mappings (change if something already uses these).
WEB_PORT=8088
API_PORT=8080
POSTGRES_PORT=5432
